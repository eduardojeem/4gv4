NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_LOCALE=es-PY
NEXT_PUBLIC_CURRENCY=PYG
NEXT_PUBLIC_TAX_RATE=0.10

# Public Session Secret (for JWT tokens in public portal)
PUBLIC_SESSION_SECRET=your-secret-key-change-in-production-min-32-chars

# Google reCAPTCHA v3 (for public portal security)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Public support WhatsApp (international format without '+')
NEXT_PUBLIC_SUPPORT_WHATSAPP=595981234567

# WhatsApp Business Number (for customer communications)
NEXT_PUBLIC_WHATSAPP_BUSINESS=595981234567

# WhatsApp Cloud API (server-side delivery for repairs communications)
# Token permanente o de sistema de Meta
WHATSAPP_CLOUD_API_TOKEN=your_whatsapp_cloud_api_token
# Phone Number ID de WhatsApp Cloud (no es el numero telefonico)
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
# Optional: Graph API version
WHATSAPP_CLOUD_API_VERSION=v21.0

# Repair QR Code Secret (for hash generation and verification)
# IMPORTANT: Change this to a random 32+ character string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REPAIR_QR_SECRET=change-this-to-a-secure-random-string-in-production

# Application Base URL (for QR code generation and SEO)
# In production, this should be your domain (e.g., https://tu-dominio.com)
# In development, it will automatically use window.location.origin
NEXT_PUBLIC_APP_URL=https://tu-dominio.com
NEXT_PUBLIC_BASE_URL=https://tu-dominio.com

# Vercel V0 API (for AI-powered component generation)
V0_API_KEY=your_v0_api_key
V0_PROJECT_ID=your_v0_project_id
